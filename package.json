{
  "name": "cyber-vault-mvp",
  "version": "0.1.0",
  "description": "Sistema de gestión de credenciales y monitoreo de vulnerabilidades con Zero-Knowledge y IPFS",
  "type": "commonjs",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "test:docker": "./infra/scripts/test-local.sh docker",
    "test:kubernetes": "./infra/scripts/test-local.sh kubernetes",
    "build": "tsc",
    "build:ext": "node scripts/build-extension.mjs",
    "build:docker": "docker build -t cyber-vault/api:latest -f infra/docker/Dockerfile.api .",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests",
    "infra:start": "./infra/scripts/start-local.sh",
    "infra:stop": "./infra/scripts/stop-local.sh",
    "infra:scan": "./infra/scripts/security-scan.sh"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.5.4",
    "@types/pako": "^2.0.4",
    "bech32": "^2.0.0",
    "express": "^4.19.2",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.8.2",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
